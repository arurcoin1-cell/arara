function getNearestRim(customPos)
    local root = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
    local origin = customPos or (root and root.Position)
    if not origin then return nil, math.huge end
    local dist, rim = math.huge, nil
    for _, r in ipairs(rimCache) do
        if r and r:IsA("BasePart") then
            -- Skip the friendly hoop via Physics Distance (Immune to instance resets and swish-hitbox mismatches)
            if ArurHubData.TeamGoalCheckEnabled and blockedRim and typeof(blockedRim) == "Instance" and blockedRim:IsA("BasePart") then
                if (r.Position - blockedRim.Position).Magnitude < 25 then
                    continue
                end
            end
            local rFlat = Vector3.new(r.Position.X, origin.Y, r.Position.Z)
            local d = (rFlat - origin).Magnitude
            if d < dist then dist = d; rim = r end
        end
    end
    return rim, dist
end

