local function onJump()
    if not ArurHubData.AimbotEnabled or not ArurHubData.HasBall() then return end
    
    -- Ensure the one-time breach was successful
    if not _G.ArurHubMapping then 
        warn("ARURHUB: No Mapping Found yet! Cannot calculate remote.")
        return 
    end

    local waitTime = ArurHubData.RandomizeWait and (math.random(15, 25) / 100) or ArurHubData.JumpWaitTime
    local bufferTime = 0.05

    -- PHASE 1: JUMP LAUNCH
    task.wait(waitTime - bufferTime)

    -- PHASE 2: MID-AIR SNAPSHOT (0.20s in)
    local rimPart, dist = getNearestRim()
    if not rimPart or dist > 74 then return end
    
    local head = lp.Character and lp.Character:FindFirstChild('Head')
    if not head then return end
    local root = lp.Character and lp.Character:FindFirstChild('HumanoidRootPart')
    local vOff = Vector3.zero
    
    if root then
        local tVel = Vector3.new(root.AssemblyLinearVelocity.X, 0, root.AssemblyLinearVelocity.Z)
        local toRim = (rimPart.Position - root.Position).Unit
        local rVec = Vector3.new(-toRim.Z, 0, toRim.X) 
        local fSpeed, sSpeed = tVel:Dot(toRim), tVel:Dot(rVec)
        local baseOff = (math.abs(fSpeed) > math.abs(sSpeed)) and (fSpeed > 0 and toRim * (0.1 * fSpeed) or toRim * (0.2 * fSpeed)) or (rVec * (0.05 * sSpeed))
        -- Proximity Damping: Weaken prediction as you get closer to avoid overshooting
        vOff = baseOff * math.clamp(dist / 90, 0.2, 1.0)
    end
    
    local arcBase = (ArurHubData.AimbotMode == 'Low Arc' and arcLow(dist)) or (ArurHubData.AimbotMode == 'High Arc' and arcHigh(dist)) or arcLow(dist)
    local arcBonus = waitTime > 0.25 and 5 or 0 -- Effectively 0
    local arcV = (ArurHubData.AimbotMode == 'Low Arc') and arcBase or (arcBase + arcBonus)
    local targetP = rimPart.Position + Vector3.new(0, arcV, 0) + vOff
    local p = head.Position
    local d = (targetP - p).Unit 
    
    local calculatedPower = (ArurHubData.AimbotMode == 'Low Arc' and powerForDistance(dist)) or 85
    
    -- PHASE 3: FINAL Apex Completion
    task.wait(bufferTime)

    lp:SetAttribute('Power', calculatedPower)
    
    -- Sync Trajectory (Visual Path)
    if ArurHubData.TrajectoryEnabled then
        local p_visual = head.Position + (d * 2.25)
        local control = ((p_visual + rimPart.Position) / 2) + Vector3.new(0, (arcV * 0.95), 0)
        
        local points = {}
        for i = 0, 30 do
            local t = i / 30
            local pos = (1-t)^2*p_visual + 2*(1-t)*t*control + t^2*rimPart.Position
            table.insert(points, pos)
        end

        lastShotInfo = {
            time = tick(), 
            points = points,
            mode = ArurHubData.TrajectoryMode, 
            color = ArurHubData.TrajectoryColor, 
            trans = ArurHubData.TrajectoryTransparency
        }
    end

    -- Construct the payload using the cached map
    local valMap = { X1 = p.X, Y1 = p.Y, Z1 = p.Z, X2 = d.X, Y2 = d.Y, Z2 = d.Z }
    local finalTable = {}
    for _, key in ipairs(_G.ArurHubMapping) do
        table.insert(finalTable, buffer.fromstring(tostring(valMap[key])))
    end

    local shootRem = replicated_storage.Remotes:FindFirstChild("ShootingEvent")
    if shootRem then
        shootRem:FireServer(calculatedPower, finalTable, _G.ArurHubCode)
    end
end

