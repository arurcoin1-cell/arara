local NoJumpPowerData = {
    {14,30},{18,35},{22,40},{26,45},{31,50},{35,55},{40,60},
    {44,65},{48,70},{56,75},{61,80},{68,85}
}
local NoJumpArcData = {
    {8,15},{13,8},{14,6},{16,10},{18,8},{19,14},{22,12},{24,20},{25,14},{26,10},
    {29,25},{31,18},{33,28},{35,20},{38,35},{40,28},{44,36},{48,45},
    {50,58},{54,50},{56,40},{58,60},{61,50},{63,68},{64,60},{66,55},{67,50},{68,45}
}
local NoJumpHighPowerData = {
    {68,85}
}
local NoJumpHighArcData = {
    {8,110},{13,109},{16,108},{19,107},{22,106},{26,105},{29,104},{31,102},
    {33,100},{35,98},{38,96},{40,94},{44,92},{48,88},{50,86},{54,83},
    {56,80},{58,75},{61,71},{63,68},{64,62},{66,55},{67,40},{68,37}
}
local function noJumpPower(d)
    local targetTable = (ArurHubData.NoJumpMode == "High Arc") and NoJumpHighPowerData or NoJumpPowerData
    for _, v in ipairs(targetTable) do if d <= v[1] then return v[2] end end
    return targetTable[#targetTable][2]
end
local function noJumpArc(d)
    local targetTable = (ArurHubData.NoJumpMode == "High Arc") and NoJumpHighArcData or NoJumpArcData
    for _, v in ipairs(targetTable) do if d < v[1] then return v[2] end end
    return targetTable[#targetTable][2]
end

function ArurHubData.triggerNoJumpShot()
    if not ArurHubData.NoJumpEnabled then return end
    if not ArurHubData.HasBall() then return end
    if not _G.ArurHubMapping then
        warn("ARURHUB: No Mapping Found yet! Cannot calculate remote.")
        return
    end

    local rimPart, dist = getNearestRim()
    if not rimPart or dist > 68 then return end

    local power = noJumpPower(dist)
    local arc   = noJumpArc(dist)

    local head = lp.Character and lp.Character:FindFirstChild("Head")
    if not head then return end
    local root = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")

    local arcV = arc
    local vOff = Vector3.zero
    if root then
        local tVel = Vector3.new(root.AssemblyLinearVelocity.X, 0, root.AssemblyLinearVelocity.Z)
        local toRim = (rimPart.Position - root.Position).Unit
        local rVec = Vector3.new(-toRim.Z, 0, toRim.X)
        local fSpeed = tVel:Dot(toRim)
        local sSpeed = tVel:Dot(rVec)

        local fMult
        if ArurHubData.NoJumpMode == "High Arc" then
            -- High Arc: Forward (needs tiny bit lower -> 0.08), Backward (needs higher -> 0.05)
            fMult = (fSpeed > 0) and 0.08 or 0.05
        else
            -- Low Arc: Forward (too low -> lower mult), Backward (fine)
            fMult = (fSpeed > 0) and 0.03 or 0.05
        end

        -- Forward/Backward affects arc height
        arcV = arcV - (fSpeed * fMult)

        -- Side-to-Side affects horizontal target position (vOff)
        vOff = rVec * (sSpeed * 0.1)
    end

    local p = head.Position
    local targetP = rimPart.Position + Vector3.new(0, arcV, 0) + vOff
    local d = (targetP - p).Unit

    -- Store for trajectory display
    if ArurHubData.TrajectoryEnabled then
        local p_visual = p + (d * 2.25)
        local control = ((p_visual + rimPart.Position + vOff) / 2) + Vector3.new(0, arcV * 0.95, 0)
        local points = {}
        for i = 0, 30 do
            local t = i / 30
            points[i+1] = (1-t)^2*p_visual + 2*(1-t)*t*control + t^2*(rimPart.Position + vOff)
        end
        lastShotInfo = {
            time  = tick(),
            points = points,
            mode  = ArurHubData.TrajectoryMode,
            color = ArurHubData.TrajectoryColor,
            trans = ArurHubData.TrajectoryTransparency
        }
    end

    lp:SetAttribute('Power', power)
    local valMap = { X1 = p.X, Y1 = p.Y, Z1 = p.Z, X2 = d.X, Y2 = d.Y, Z2 = d.Z }
    local finalTable = {}
    for _, key in ipairs(_G.ArurHubMapping) do
        table.insert(finalTable, buffer.fromstring(tostring(valMap[key])))
    end
    local shootRem = replicated_storage.Remotes:FindFirstChild("ShootingEvent")
    if shootRem then
        shootRem:FireServer(power, finalTable, _G.ArurHubCode)
    end
end

