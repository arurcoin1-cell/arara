print("starting...")
task.wait(2)

local rs = game:GetService("ReplicatedStorage")
local shootRemote = rs.Remotes.ShootingEvent
print("remote: " .. tostring(shootRemote ~= nil))

local CoreGui = game:GetService("CoreGui")
local drop = CoreGui:FindFirstChild("AHTest") or Instance.new("Folder")
drop.Name = "AHTest"
drop.Parent = CoreGui

drop.ChildAdded:Connect(function(c)
    if c:IsA("StringValue") then
        print("RESULT: " .. c.Value)
        c:Destroy()
    end
end)

local actors = getactors()
print("actors: " .. #actors)

local code = [[
    task.wait(0.5)
    local rs = game:GetService("ReplicatedStorage")
    local rem = rs.Remotes.ShootingEvent
    local drop = game:GetService("CoreGui"):FindFirstChild("AHTest")
    if not drop then print("[A] no folder") return end

    local captured = false
    local mt = getrawmetatable(game)
    setreadonly(mt, false)
    local old = mt.__namecall
    mt.__namecall = newcclosure(function(self, ...)
        if getnamecallmethod() == "FireServer" and self == rem and not captured then
            captured = true
            local args = {...}
            local result = "args=" .. #args
            for i, a in ipairs(args) do
                if typeof(a) == "string" then
                    result = result .. " code='" .. a .. "'"
                elseif typeof(a) == "table" then
                    result = result .. " tbl[" .. #a .. "]"
                    for j, elem in ipairs(a) do
                        if typeof(elem) == "buffer" then
                            result = result .. "=" .. tostring(tonumber(buffer.tostring(elem)))
                        end
                    end
                elseif typeof(a) == "number" then
                    result = result .. " power=" .. a
                end
            end
            local sv = Instance.new("StringValue")
            sv.Name = "R"
            sv.Value = result
            sv.Parent = drop
            mt.__namecall = old
            setreadonly(mt, true)
        end
        return old(self, ...)
    end)
    setreadonly(mt, true)
    print("[A] hook ready - shoot!")
]]

for i, actor in ipairs(actors) do
    pcall(run_on_actor, actor, code)
end
print("done - shoot now!")
