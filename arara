local function performSelfPass()
    if not ArurHubData.HasBall() then
        notify("You don't have the ball!")
        return
    end
    if not _G.ArurHubMapping then 
        warn("ARURHUB: No Mapping Found yet! Cannot calculate remote.")
        return 
    end
    
    notify("Performing Silent Self Pass...")
    local char = lp.Character
    local head = char and char:FindFirstChild('Head')
    if not head then return end
    
    local calculatedPower = 85
    lp:SetAttribute('Power', calculatedPower)
    
    local rawDirection = camera.CFrame.LookVector
    if ArurHubData.SelfPassDirection == "Character" then
        local root = char:FindFirstChild('HumanoidRootPart')
        if root then rawDirection = root.CFrame.LookVector end
    end
    
    -- FLATTEN DIRECTION: Ignore Y-tilt of camera/character to maintain consistent arc
    local horizontalDir = Vector3.new(rawDirection.X, 0, rawDirection.Z).Unit
    
    -- MAGIC SELF-PASS TRAJECTORY (0.225 Horizontal / 0.985 Vertical)
    local d = (horizontalDir * 0.225) + Vector3.new(0, 0.985, 0)
    d = d.Unit -- Ensure exact vector normalization
    
    local p = head.Position
    -- This perfectly mirrors the 'winning' shot you decoded earlier!
    
    local valMap = { X1 = p.X, Y1 = p.Y, Z1 = p.Z, X2 = d.X, Y2 = d.Y, Z2 = d.Z }
    local finalTable = {}
    
    for _, key in ipairs(_G.ArurHubMapping) do
        table.insert(finalTable, buffer.fromstring(tostring(valMap[key])))
    end

    local shootRem = replicated_storage.Remotes:FindFirstChild("ShootingEvent")
    if shootRem then
        shootRem:FireServer(calculatedPower, finalTable, _G.ArurHubCode)
    end

end

