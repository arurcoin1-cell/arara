-- RANK & STREAK ICONS OVERHEAD LOGIC
local StreakIconsEnabled = false

local function removeRankIconGui(player)
    if rankIconGuis[player] then
        rankIconGuis[player]:Destroy()
        rankIconGuis[player] = nil
    end
    if rankIconConnections[player] then
        rankIconConnections[player]:Disconnect()
        rankIconConnections[player] = nil
    end
end

local function createRankIconGui(player)
    removeRankIconGui(player)
    if not RankIconsEnabled and not StreakIconsEnabled then return end

    local character = player.Character
    if not character then return end
    local head = character:FindFirstChild("Head") or character:FindFirstChild("HumanoidRootPart")
    if not head then return end
    local hrp = character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    
    local nameTag = hrp:FindFirstChild("NameTag")
    if not nameTag then return end
    local mainFrame = nameTag:FindFirstChild("MainFrame")
    if not mainFrame then return end

    local sourceRank = mainFrame:FindFirstChild("RankIcon")
    local sourceStreak = mainFrame:FindFirstChild("StreakIcon")
    local sourceStreakLabel = sourceStreak and sourceStreak:FindFirstChild("AmountLabel")
    
    local function getStreakAmount()
        return tonumber(sourceStreakLabel and sourceStreakLabel.Text) or 0
    end

    local billboard = Instance.new("BillboardGui")
    billboard.Name = "ArurRankOverhead"
    billboard.Size = UDim2.new(2, 0, 2, 0)
    billboard.StudsOffset = Vector3.new(0, 2.5, 0)
    billboard.AlwaysOnTop = false
    billboard.LightInfluence = 0
    billboard.ResetOnSpawn = false
    billboard.MaxDistance = nameTag.MaxDistance > 0 and nameTag.MaxDistance or 100 -- Distance Clipping
    billboard.Adornee = head
    billboard.Parent = hrp

    local container = Instance.new("Frame")
    container.Name = "MainFrame"
    container.Size = UDim2.new(1, 0, 1, 0)
    container.BackgroundTransparency = 1
    container.Parent = billboard

    local layout = Instance.new("UIListLayout")
    layout.FillDirection = Enum.FillDirection.Horizontal
    layout.HorizontalAlignment = Enum.HorizontalAlignment.Center
    layout.VerticalAlignment = Enum.VerticalAlignment.Center
    layout.Padding = UDim.new(0.01, 0) -- Tightened spacing
    layout.Parent = container

    local function addAspectRatio(obj)
        local arc = Instance.new("UIAspectRatioConstraint")
        arc.AspectRatio = 1
        arc.AspectType = Enum.AspectType.FitWithinMaxSize
        arc.DominantAxis = Enum.DominantAxis.Height
        arc.Parent = obj
    end

    local clonedRank = sourceRank and sourceRank:Clone()
    if clonedRank then
        clonedRank.Size = UDim2.new(1, 0, 0.9, 0)
        addAspectRatio(clonedRank)
        clonedRank.Parent = container
        clonedRank.Visible = false
    end

    local clonedStreak = sourceStreak and sourceStreak:Clone()
    if clonedStreak then
        clonedStreak.Size = UDim2.new(1, 0, 0.9, 0)
        addAspectRatio(clonedStreak)
        clonedStreak.Parent = container
        clonedStreak.Visible = false
        clonedStreak.BackgroundTransparency = 1
        
        local amountLabel = clonedStreak:FindFirstChild("AmountLabel")
        if amountLabel then
            amountLabel.AnchorPoint = Vector2.new(0.5, 0.5)
            amountLabel.Position = UDim2.new(0.5, 0, 0.53, 0)
        end
    end

    local lastState = ""
    local function updateLayout()
        local streakActive = StreakIconsEnabled and sourceStreak ~= nil and getStreakAmount() > 0
        local rankActive = RankIconsEnabled and sourceRank ~= nil
        local state = tostring(streakActive) .. tostring(rankActive)
        
        if not streakActive and not rankActive then
            billboard.Enabled = false
            return
        end
        billboard.Enabled = true

        if state ~= lastState then
            lastState = state
            if rankActive and streakActive then
                billboard.Size = UDim2.new(4, 0, 1.5, 0)
                if clonedRank then clonedRank.Visible = true end
                if clonedStreak then clonedStreak.Visible = true end
            elseif rankActive or streakActive then
                billboard.Size = UDim2.new(1.8, 0, 1.8, 0)
                if clonedRank then clonedRank.Visible = rankActive end
                if clonedStreak then clonedStreak.Visible = streakActive end
            end
        end
    end

    updateLayout()

    local conn = game:GetService("RunService").Heartbeat:Connect(function()
        if not character or not character.Parent then return end
        
        if clonedRank and RankIconsEnabled then
            local sr = mainFrame:FindFirstChild("RankIcon")
            if sr then clonedRank.Image = sr.Image end
        end
        
        if clonedStreak and StreakIconsEnabled then
            local ss = mainFrame:FindFirstChild("StreakIcon")
            if ss then
                clonedStreak.ImageRectOffset = ss.ImageRectOffset
                clonedStreak.ImageRectSize = ss.ImageRectSize
                clonedStreak.Image = ss.Image
                local al = ss:FindFirstChild("AmountLabel")
                if al then
                    local clonedLabel = clonedStreak:FindFirstChild("AmountLabel")
                    if clonedLabel then clonedLabel.Text = al.Text end
                end
            end
        end
        
        updateLayout()
    end)

    rankIconConnections[player] = conn
    rankIconGuis[player] = billboard
end

local function applyRankIcons()
    for _, player in ipairs(game:GetService("Players"):GetPlayers()) do
        if player ~= lp then createRankIconGui(player) end
    end
end

local function clearAllRankIcons()
    for player, _ in pairs(rankIconGuis) do removeRankIconGui(player) end
    rankIconConnections = {}
    rankIconGuis = {}
end

