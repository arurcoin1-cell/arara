    for _, otherPlayer in pairs(players:GetPlayers()) do
        if otherPlayer ~= lp then
            local root = otherPlayer.Character and otherPlayer.Character:FindFirstChild('HumanoidRootPart')
            if root then
                local dist = (Vector2.new(root.Position.X, root.Position.Z) - Vector2.new(myRoot.Position.X, myRoot.Position.Z)).Magnitude
