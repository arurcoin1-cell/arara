print("=== ARURHUB PARALLEL MEMORY SCANNER ===")

local actors = getactors()
print("Found " .. #actors .. " actors.")
if #actors == 0 then return end

-- Create a shared StringValue in ReplicatedStorage for communication
local rs = game:GetService("ReplicatedStorage")
local sharedVal = rs:FindFirstChild("AH_Mapping_Result")
if not sharedVal then
    sharedVal = Instance.new("StringValue")
    sharedVal.Name = "AH_Mapping_Result"
    sharedVal.Parent = rs
end
sharedVal.Value = ""

-- Listen for the result from the actors
sharedVal:GetPropertyChangedSignal("Value"):Connect(function()
    local val = sharedVal.Value
    if val ~= "" then
        print("========================================")
        print("🚀 MAPPING FOUND VIA PARALLEL GETGC!")
        print("Result: " .. val)
        print("========================================")
    end
end)

-- Inject getgc scanner into the actors
local scanCode = [[
    task.wait(0.5)
    local rs = game:GetService("ReplicatedStorage")
    local sharedVal = rs:FindFirstChild("AH_Mapping_Result")
    if not sharedVal then return end

    -- Helper to verify mapping
    local function isMappingTable(t)
        if type(t) ~= "table" then return false end
        local count = 0
        for k, v in pairs(t) do
            count = count + 1
            if count > 10 then return false end
        end
        if count ~= 6 then return false end
        
        local matches = 0
        for i=1, 6 do
            local val = t[i]
            if type(val) == "string" and val:match("^[XYZ][12]$") then
                matches = matches + 1
            end
        end
        return matches == 6
    end

    -- Run getgc inside the actor's VM
    local ok, gc = pcall(getgc, true)
    if ok and type(gc) == "table" then
        local funcsScanned = 0
        for _, obj in pairs(gc) do
            if type(obj) == "function" then
                funcsScanned = funcsScanned + 1
                local okU, upvals = pcall(debug.getupvalues, obj)
                if okU and type(upvals) == "table" then
                    for _, up in pairs(upvals) do
                        if isMappingTable(up) then
                            sharedVal.Value = table.concat(up, ",")
                            return
                        end
                    end
                end
            end
        end
        print("[Actor] Scanned " .. funcsScanned .. " functions but didn't find mapping.")
    else
        print("[Actor] getgc failed or restricted inside actor.")
    end
]]

for i, actor in ipairs(actors) do
    pcall(run_on_actor, actor, scanCode)
end

print("Scanning parallel VMs... wait a moment.")
