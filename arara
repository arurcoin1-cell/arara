function ArurHubData.triggerAutoPass(targetIndex)
    if not ArurHubData.PassAimbotEnabled or not ArurHubData.HasBall() then return end
    
    local targetPlr = ArurHubData.PersistentPassTargets[targetIndex]
    if not targetPlr or not targetPlr.Character then return end
    
    local targetVel = ArurHubData.PersistentTargetVelocities[targetPlr] or Vector3.zero

    local myChar = lp.Character
    local myHead = myChar and myChar:FindFirstChild("Head")
    if not myHead then return end

    local targetHead = targetPlr.Character:FindFirstChild("Head")
    if not targetHead then return end

    local dist = (targetHead.Position - myHead.Position).Magnitude
    if dist > 140 then return end

    local travelTime = dist / 90
    local leadMult = 1.6
    
    if dist < 45 then
        leadMult = 1.7 + ((45 - dist) * 0.08)
    elseif dist < 55 then
        leadMult = 1.6 + ((55 - dist) * 0.01)
    elseif dist > 125 then
        leadMult = 1.9 - ((dist - 125) * 0.005)
    elseif dist > 100 then
        leadMult = 1.65 + ((dist - 100) * 0.01)
    elseif dist > 95 then
        leadMult = 1.75 - ((dist - 95) * 0.02)
    elseif dist > 80 then
        leadMult = 1.6 + ((dist - 80) * 0.01)
    end

    local predictionVector = targetVel * travelTime * leadMult * (ArurHubData.PassPredictionStrength or 1)
    local leadPos = targetHead.Position + predictionVector

    local arcV = 1 
    if dist >= 80 then
        arcV = 28 + ((dist - 80) * 1.2)
    elseif dist >= 65 then
        arcV = 16 + ((dist - 65) * 0.8)
    elseif dist < 45 then
        arcV = ((dist * 8) / 45) - 10
    else
        arcV = 1
    end
    arcV = math.clamp(arcV, -10, 85)

    local horizVel = Vector2.new(targetVel.X, targetVel.Z)
    local expectedTargetP = leadPos + Vector3.new(0, arcV, 0)
    local pPos = myHead.Position
    local dirVector = (expectedTargetP - pPos).Unit
    local horizDir = Vector2.new(dirVector.X, dirVector.Z).Unit
    
    if horizVel.Magnitude > 2.0 then
        local dotP = horizVel.Unit:Dot(horizDir)
        if dotP > 0.4 then
            local dynamicBoost = 5
            if dist > 40 then dynamicBoost = 5 + ((dist - 40) * 0.75) end
            
            arcV = arcV + dynamicBoost
            arcV = math.clamp(arcV, -10, 85)
            expectedTargetP = leadPos + Vector3.new(0, arcV, 0)
            dirVector = (expectedTargetP - pPos).Unit
        end
    end

    local valMap = { 
        X1 = pPos.X, Y1 = pPos.Y, Z1 = pPos.Z, 
        X2 = dirVector.X, Y2 = dirVector.Y, Z2 = dirVector.Z 
    }
    
    local finalTable = {}
    if not _G.ArurHubMapping then return end
    for _, key in ipairs(_G.ArurHubMapping) do
        table.insert(finalTable, buffer.fromstring(tostring(valMap[key])))
    end

    lp:SetAttribute("Power", 85)
    local shootRem = replicated_storage.Remotes:FindFirstChild("ShootingEvent")
    if shootRem and _G.ArurHubCode then
        shootRem:FireServer(85, finalTable, _G.ArurHubCode)
    end
end

