run_service.Heartbeat:Connect(function(dt)
    if not ArurHubData.LockToPlayer then 
        if isTargetHUDVisible then ArurHubData.animateTargetHUD(false) end
        return 
    end
    ArurHubData.lockAccum = ArurHubData.lockAccum + dt
    if ArurHubData.lockAccum < 0.05 then return end -- ~20fps cap
    ArurHubData.lockAccum = 0

    local myChar = lp.Character
    local rPart = ArurHubData.pRoot
    local activeHum = ArurHubData.pHum

    local function disableLock()
        ArurHubData.LockToPlayer = false
        ArurHubData.LockedPlayer = nil
        ArurHubData.animateTargetHUD(false)
        if not sync_guards.lock then
            sync_guards.lock = true
            if lock_toggle then lock_toggle.set(false) end
            sync_guards.lock = false
        end
    end

    if ArurHubData.HasBall() then
        disableLock()
    elseif not ArurHubData.LockedPlayer or not ArurHubData.LockedPlayer.Character or not ArurHubData.LockedPlayer.Character:FindFirstChild("HumanoidRootPart") then
        ArurHubData.animateTargetHUD(false)
        return
    else
        local tRoot = ArurHubData.LockedPlayer.Character:FindFirstChild("HumanoidRootPart")
        if tRoot and rPart and activeHum then
            local myPos    = rPart.Position
            local tPosReal = tRoot.Position
            local realDist = (Vector3.new(myPos.X, 0, myPos.Z) - Vector3.new(tPosReal.X, 0, tPosReal.Z)).Magnitude
            
            -- FIX: Prediction decreases gracefully as distance grows, dropping to 0 at ~12 studs.
            local scaler   = math.clamp(1 - ((realDist - 4) / 8), 0, 1) 
            local tPos     = tPosReal + (tRoot.Velocity * ArurHubData.PredictionOffset * scaler)
            local dist     = (Vector2.new(myPos.X, myPos.Z) - Vector2.new(tPos.X, tPos.Z)).Magnitude

            if ArurHubData.TargetHUDEnabled then
                ArurHubData.updateTargetHUD(ArurHubData.LockedPlayer, realDist)
            else
                ArurHubData.animateTargetHUD(false)
            end

            if math.abs(dist - ArurHubData.FOLLOW_DIST) > ArurHubData.DEAD_ZONE then
                local dest
                if realDist > 12 then
                    -- Direct pursuit when far away
                    dest = tPosReal
                else
                    -- "Danclike" prediction/offset when close
                    dest = tPos + (tRoot.Velocity.Magnitude > 0.1 and tRoot.Velocity.Unit * ArurHubData.FOLLOW_DIST or Vector3.zero)
                end
                activeHum:MoveTo(dest)
            end
        end
    end
end)

