function ArurHubData.createMobileToggle(name, uiName, dataKey, toggleObj, positionOffset)
    local stateKey = "mobile_" .. uiName:lower() .. "_gui"
    local mobileGui, mobileBtn, heartbeat
    
    return function(state)
        if state then
            if not isMobile then
                ArurHubData.SendNotification('Mobile only feature.', 3, Color3.fromRGB(220, 40, 70))
                return
            end

            local existing = playerGui:FindFirstChild(stateKey)
            if existing then existing:Destroy() end

            mobileGui = Instance.new('ScreenGui')
            mobileGui.Name = stateKey
            mobileGui.ResetOnSpawn = false
            mobileGui.Parent = playerGui

            -- Pill button
            mobileBtn = Instance.new('TextButton')
            mobileBtn.Name            = 'ToggleButton'
            mobileBtn.Size            = UDim2.fromOffset(110, 36)
            mobileBtn.Position        = loadMobilePos(stateKey) or UDim2.new(0.9, -55, 0.2, positionOffset)
            mobileBtn.AnchorPoint     = Vector2.new(0.5, 0.5)
            mobileBtn.BackgroundColor3 = Color3.fromRGB(22, 22, 28)
            mobileBtn.BorderSizePixel = 0
            mobileBtn.AutoButtonColor = false
            mobileBtn.Text            = ''
            mobileBtn.Active          = true
            mobileBtn.Draggable       = true
            mobileBtn.Parent          = mobileGui

            Instance.new('UICorner', mobileBtn).CornerRadius = UDim.new(1, 0)

            -- Outer glow stroke (starts red)
            local btnStroke = Instance.new('UIStroke', mobileBtn)
            btnStroke.Thickness   = 1.5
            btnStroke.Color       = Color3.fromRGB(220, 50, 80)
            btnStroke.Transparency = 0.2

            -- Status dot
            local dot = Instance.new('Frame', mobileBtn)
            dot.Name             = 'Dot'
            dot.Size             = UDim2.fromOffset(7, 7)
            dot.Position         = UDim2.new(0, 10, 0.5, 0)
            dot.AnchorPoint      = Vector2.new(0, 0.5)
            dot.BackgroundColor3 = Color3.fromRGB(220, 50, 80)
            dot.BorderSizePixel  = 0
            Instance.new('UICorner', dot).CornerRadius = UDim.new(1, 0)

            -- Label
            local lbl = Instance.new('TextLabel', mobileBtn)
            lbl.Size                  = UDim2.new(1, -26, 1, 0)
            lbl.Position              = UDim2.new(0, 22, 0, 0)
            lbl.BackgroundTransparency = 1
            lbl.TextColor3            = Color3.fromRGB(220, 220, 230)
            lbl.Font                  = Enum.Font.GothamBold
            lbl.TextSize              = 11
            lbl.Text                  = name
            lbl.TextXAlignment        = Enum.TextXAlignment.Left
            lbl.TextTruncate          = Enum.TextTruncate.AtEnd

            mobileBtn.MouseButton1Click:Connect(function()
                if toggleObj then
                    toggleObj.set(not ArurHubData[dataKey])
                end
            end)

            mobileBtn.InputEnded:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                    saveMobilePos(stateKey, mobileBtn.Position)
                end
            end)

            heartbeat = run_service.RenderStepped:Connect(function()
                if not mobileBtn or not mobileBtn.Parent then
                    if heartbeat then heartbeat:Disconnect() end
                    return
                end
                local on = ArurHubData[dataKey]
                local col = on and Color3.fromRGB(80, 220, 120) or Color3.fromRGB(220, 50, 80)
                dot.BackgroundColor3  = col
                btnStroke.Color       = col
            end)

            ArurHubData.SendNotification(name .. " Mobile UI ON", 2.5, Color3.fromRGB(80, 220, 120))
        else
            if heartbeat then heartbeat:Disconnect(); heartbeat = nil end
            if mobileGui then mobileGui:Destroy(); mobileGui = nil; mobileBtn = nil end
            ArurHubData.SendNotification(name .. " Mobile UI OFF", 2, Color3.fromRGB(220, 50, 80))
        end
    end
end

