local function refreshBodyAura()
    local char = lp.Character
    if not char then return end

    -- 1. Surgical Cleanup
    for _, obj in ipairs(char:GetDescendants()) do
        if obj:GetAttribute("ArurHub_AuraEffect") then
            obj:Destroy()
        end
    end

    if not ArurHubData.bodyAuraEnabled then 
        char:SetAttribute("Aura", nil)
        return 
    end

    local auraTarget = ArurHubCosmetics.BodyAuraNameMap[ArurHubData.currentBodyAura]
    if not auraTarget then return end

    -- Direct extraction path
    local shop = replicated_storage:FindFirstChild("ShopItems")
    local auraFolder = shop and shop:FindFirstChild("Aura")
    local auraModel = auraFolder and auraFolder:FindFirstChild(auraTarget)
    
    if not auraModel then return end

    -- 2. Smart Mirroring (R6 & R15 Compatible)
    local function getTargetPart(name)
        -- Map common part names between rig types
        local mapping = {
            ["Torso"] = {"Torso", "UpperTorso", "LowerTorso"},
            ["Left Arm"] = {"Left Arm", "LeftUpperArm", "LeftHand"},
            ["Right Arm"] = {"Right Arm", "RightUpperArm", "RightHand"},
            ["Left Leg"] = {"Left Leg", "LeftUpperLeg", "LeftFoot"},
            ["Right Leg"] = {"Right Leg", "RightUpperLeg", "RightFoot"}
        }
        
        local targets = mapping[name] or {name}
        for _, t in ipairs(targets) do
            local found = char:FindFirstChild(t)
            if found then return found end
        end
        return nil
    end

    for _, auraComp in ipairs(auraModel:GetChildren()) do
        if auraComp.Name == "Rig" and auraComp:IsA("Model") then
            -- DEEP RIG EXTRACTION: Go inside the NPC blueprint
            for _, rigPart in ipairs(auraComp:GetChildren()) do
                if rigPart:IsA("BasePart") then
                    local targetPart = getTargetPart(rigPart.Name)
                    if targetPart then
                        for _, effect in ipairs(rigPart:GetChildren()) do
                            local clone = effect:Clone()
                            clone:SetAttribute("ArurHub_AuraEffect", true)
                            clone:SetAttribute("Aura", true)
                            
                            -- Physics Safety: Ensure cloned parts never interfere with movement
                            if clone:IsA("BasePart") then
                                clone.CanCollide = false
                                clone.CanTouch = false
                                clone.CanQuery = false
                            end

                            if clone:IsA("ParticleEmitter") or clone:IsA("Light") or clone:IsA("Beam") then
                                clone.Enabled = true
                            end
                            clone.Parent = targetPart
                        end
                    end
                end
            end
        elseif auraComp.Name ~= "Rig" then 
            -- STANDALONE EFFECTS: Mirror non-rig items directly
            local targetPart = getTargetPart(auraComp.Name)
            if targetPart and targetPart:IsA("BasePart") then
                for _, effect in ipairs(auraComp:GetChildren()) do
                    local clone = effect:Clone()
                    clone:SetAttribute("ArurHub_AuraEffect", true)
                    clone:SetAttribute("Aura", true)
                    
                    if clone:IsA("BasePart") then
                        clone.CanCollide = false
                        clone.CanTouch = false
                        clone.CanQuery = false
                    end

                    if clone:IsA("ParticleEmitter") or clone:IsA("Light") or clone:IsA("Beam") then
                        clone.Enabled = true
                    end
                    clone.Parent = targetPart
                end
            else
                local clone = auraComp:Clone()
                clone:SetAttribute("ArurHub_AuraEffect", true)
                clone:SetAttribute("Aura", true)
                clone.Parent = char
            end
        end
    end

    -- 3. LOD/Attribute Sync
    local parts = {"Head", "HumanoidRootPart", "Torso", "UpperTorso", "Left Arm", "Right Arm"}
    for _, partName in ipairs(parts) do
        local p = char:FindFirstChild(partName)
        if p then p:SetAttribute("Aura", auraTarget) end
    end
    char:SetAttribute("Aura", auraTarget)
end






