local isTargetHUDVisible = false
function ArurHubData.animateTargetHUD(show, adornPart)
    if isTargetHUDVisible == show then 
        if show and adornPart and targetHUDGui.Adornee ~= adornPart then
            targetHUDGui.Adornee = adornPart
        end
        return 
    end
    isTargetHUDVisible = show
    if show then
        targetHUDGui.Adornee = adornPart
        targetHUDGui.Enabled = true
        tween_service:Create(targetMain, TweenInfo.new(0.1, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {GroupTransparency = 0}):Play()
    else
        local tweenOut = tween_service:Create(targetMain, TweenInfo.new(0.1, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {GroupTransparency = 1})
        tweenOut:Play()
        tweenOut.Completed:Connect(function()
            if not isTargetHUDVisible then
                targetHUDGui.Enabled = false
                targetHUDGui.Adornee = nil
            end
        end)
    end
end

function ArurHubData.updateTargetHUD(player, dist)
    if not player or not player.Character then 
        ArurHubData.animateTargetHUD(false) 
        return 
    end
    local root = player.Character:FindFirstChild("HumanoidRootPart")
    if not root then 
        ArurHubData.animateTargetHUD(false) 
        return 
    end
    
    local rawName = ArurHubData.TargetHUDDisplayName and player.DisplayName or player.Name
    local displayName = rawName
    if #displayName > 12 then
        displayName = string.sub(displayName, 1, 10) .. "..."
    end
    targetName.Text = displayName
    
    ArurHubData.HasBball = ArurHubData.HasBall(player)
    
    ArurHubData.DistRenderStr = string.format('<font color="rgb(%d,%d,%d)">Dist: %d</font>', 
        math.floor(ArurHubData.TargetHUDDistanceColor.R * 255), 
        math.floor(ArurHubData.TargetHUDDistanceColor.G * 255), 
        math.floor(ArurHubData.TargetHUDDistanceColor.B * 255), 
        math.floor(dist)
    )

    if ArurHubData.HasBball then
        ArurHubData.NearestHoop = getNearestRim(root.Position)
        if ArurHubData.NearestHoop then
            ArurHubData.HoopDist = (ArurHubData.NearestHoop.Position - root.Position).Magnitude
            if ArurHubData.HoopDist <= 74 then
                targetDist.Text = ArurHubData.DistRenderStr .. ' | <font color="rgb(0,255,0)">In Range</font>'
            else
                targetDist.Text = ArurHubData.DistRenderStr .. ' | <font color="rgb(255,50,50)">Out Range</font>'
            end
        else
            targetDist.Text = ArurHubData.DistRenderStr
        end
    else
        targetDist.Text = ArurHubData.DistRenderStr
    end
    
    targetAccent.BackgroundColor3 = ArurHubData.TargetHUDAccentColor
    targetImage.Image = "https://www.roblox.com/headshot-thumbnail/image?userId="..player.UserId.."&width=420&height=420&format=png"
    
    -- Extract actual game Rank & Streak icons
    targetRankIcon.Visible = false
    targetStreakIcon.Visible = false
    
    local nameTag = root:FindFirstChild("NameTag")
    local mainFrame = nameTag and nameTag:FindFirstChild("MainFrame")
    if mainFrame then
        local srcRank = mainFrame:FindFirstChild("RankIcon")
        if srcRank and srcRank.Image ~= "" then
            targetRankIcon.Image = srcRank.Image
            targetRankIcon.Visible = true
        end
        
        local srcStreak = mainFrame:FindFirstChild("StreakIcon")
        if srcStreak and srcStreak.Image ~= "" then
            targetStreakIcon.Image = srcStreak.Image
            targetStreakIcon.ImageRectOffset = srcStreak.ImageRectOffset
            targetStreakIcon.ImageRectSize = srcStreak.ImageRectSize
            
            local srcAmt = srcStreak:FindFirstChild("AmountLabel")
            if srcAmt and srcAmt.Text ~= "" then
                local streakNum = tonumber(string.match(srcAmt.Text, "%d+")) or 0
                if streakNum > 0 then
                    targetStreakText.Text = srcAmt.Text
                    targetStreakIcon.Visible = true
                end
            end
        end
    end

    ArurHubData.animateTargetHUD(true, root)
end

