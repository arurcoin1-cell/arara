print("[1] SCRIPT STARTED")

local lp = game:GetService("Players").LocalPlayer
local ok2, gcResult = pcall(getgc, true)
print("[2] getgc ok=" .. tostring(ok2) .. " count=" .. (ok2 and #gcResult or "FAIL"))
if not ok2 then return end

-- Scan main thread for ANY FireServer function and print all upvalues
print("[3] === MAIN THREAD: ALL FireServer FUNCTIONS ===")
local fireCount = 0
for _, v in pairs(gcResult) do
    if typeof(v) == "function" then
        local okC, consts = pcall(debug.getconstants, v)
        if okC and consts and table.find(consts, "FireServer") then
            fireCount = fireCount + 1
            
            -- Print all constants of this function
            local constStr = ""
            for _, c in pairs(consts) do
                if typeof(c) == "string" then
                    constStr = constStr .. "'" .. c .. "' "
                end
            end
            print("[4] FireServer func #" .. fireCount .. " consts: " .. constStr)
            
            -- Print all upvalues
            local okU, upvals = pcall(debug.getupvalues, v)
            if okU and type(upvals) == "table" then
                print("[5] upval count=" .. #upvals)
                for ui, up in pairs(upvals) do
                    local utype = typeof(up)
                    if utype == "table" then
                        local info = "TABLE len=" .. #up
                        for ki, kv in pairs(up) do
                            info = info .. " [" .. tostring(ki) .. "]=" .. tostring(kv)
                        end
                        print("[6] upval[" .. ui .. "] " .. info)
                    elseif utype == "string" then
                        print("[6] upval[" .. ui .. "] STRING='" .. up .. "'")
                    else
                        print("[6] upval[" .. ui .. "] " .. utype .. "=" .. tostring(up))
                    end
                end
            else
                print("[5] getupvalues failed: " .. tostring(upvals))
            end
        end
    end
end
print("[7] Total FireServer funcs on main: " .. fireCount)
print("[8] DONE")
