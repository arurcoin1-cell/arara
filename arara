-- [ STANDALONE BACKGROUND ACTOR SCANNER ] --
local function performStandaloneActorScan()
    local actors = {}
    
    -- Primary: Try executor's built-in getactors API
    if typeof(getactors) == "function" then
        local success, res = pcall(getactors)
        if success and type(res) == "table" then
            for _, act in ipairs(res) do
                table.insert(actors, act)
            end
        end
    end
    
    -- Fallback: If getactors is broken or empty, manually scan PlayerGui for randomized Actor instances
    if #actors == 0 then
        local playerGui = game:GetService("Players").LocalPlayer:FindFirstChild("PlayerGui")
        if playerGui then
            for _, obj in ipairs(playerGui:GetDescendants()) do
                if obj:IsA("Actor") then
                    table.insert(actors, obj)
                end
            end
        end
    end

    if #actors == 0 then 
        warn("No actors found in the game to scan! Even after searching PlayerGui.")
        return 
    end
    
    print("Start.")
    local startTime = tick()
    
    local id, channel = create_comm_channel()
    local conn
    conn = channel.Event:Connect(function(mapping, code)
        local duration = tick() - startTime
        
        print("Worked!")
        print("Finished in " .. string.format("%.3f", duration) .. "s")

        -- Final verification to show what was found without table spam
        -- print("Breached context code: " .. tostring(code))

        if conn then conn:Disconnect() end
    end)

    local scannerCode = [[
        local channelId = ]] .. tostring(id) .. [[ 
        local channel
        if typeof(get_comm_channel) == "function" then
            pcall(function() channel = get_comm_channel(channelId) end)
        end
        
        local Cipher = {
            ["X1"] = "Alpha", ["Y1"] = "Beta", ["X2"] = "Gamma",
            ["Y2"] = "Delta", ["Z1"] = "Epsilon", ["Z2"] = "Zeta"
        }

        for _, v in pairs(getgc(true)) do
            if typeof(v) == "function" and islclosure(v) then 
                local success, consts = pcall(debug.getconstants, v)
                if success and consts and table.find(consts, "FireServer") then
                    local upvals = debug.getupvalues(v)
                    for _, up in pairs(upvals) do
                        if typeof(up) == "table" and #up == 6 and typeof(up[1]) == "string" and up[1]:match("[XYZ][12]") then
                            local secretCode = "Oh yeah yeah"
                            for _, sc in pairs(upvals) do
                                if typeof(sc) == "string" and #sc > 3 and not sc:find("Server") then secretCode = sc end
                            end
                            
                            if channel then
                                channel:Fire(up, secretCode)
                            else
                                local hiddenOrder = {}
                                for _, key in ipairs(up) do
                                    table.insert(hiddenOrder, Cipher[key] or "Unknown")
                                end
                                print("\nSUCCESS (Fallback Print)!")
                                print("ENCRYPTED ORDER: " .. table.concat(hiddenOrder, " -> "))
                                print("Scraped Code: " .. tostring(secretCode) .. "\n")
                            end
                            return
                        end
                    end
                end
            end
        end
    ]]

    for i = 1, math.min(#actors, 100) do 
        pcall(run_on_actor, actors[i], scannerCode)
    end
end

performStandaloneActorScan()
