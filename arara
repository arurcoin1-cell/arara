-- Custom drag: fixes teleport by converting to pure offsets before dragging
-- [ TOUCH SUPPORTED ] --
do
    local dragging, dragStart, startPos = false, nil, nil
    statsDragHeader.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            local abs = statsFrame.AbsolutePosition
            statsFrame.Position = UDim2.fromOffset(abs.X, abs.Y)
            dragStart = input.Position
            startPos = statsFrame.Position
        end
    end)
    uis.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            local delta = input.Position - dragStart
            statsFrame.Position = UDim2.fromOffset(startPos.X.Offset + delta.X, startPos.Y.Offset + delta.Y)
        end
    end)
    uis.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = false
        end
    end)
end

function ArurHubData.updateStatsUI()
    local dMade = ArurHubData.SessionOnlyStats and ArurHubData.sessionMade or (ArurHubData.lastGameMade or 0)
    local dTotal = ArurHubData.SessionOnlyStats and ArurHubData.sessionTotal or (ArurHubData.lastGameTotal or 0)
    local percent = dTotal > 0 and math.floor((dMade / dTotal) * 100) or 0
    
    statsLabel.Text = string.format("%d/%d", dMade, dTotal)
    pctLabel.Text = string.format("%d%%", percent)
    tween_service:Create(fgBarFill, TweenInfo.new(0.4, Enum.EasingStyle.Quad), {Size = UDim2.new(percent/100, 0, 1, 0)}):Play()
end

-- Networking Hook: Intercept updates while the stats menu is closed
local dEvent = replicated_storage.Remotes:FindFirstChild("dataEvent")
if dEvent then
    dEvent.OnClientEvent:Connect(function(action, category, key, value)
        if action == "Update" and category == "Stats" then
            local val = tonumber(value) or 0
            if key == "FGMade" then
                if ArurHubData.lastGameMade ~= nil and val > ArurHubData.lastGameMade then
                    ArurHubData.sessionMade = ArurHubData.sessionMade + (val - ArurHubData.lastGameMade)
                end
                ArurHubData.lastGameMade = val
                ArurHubData.updateStatsUI()
            elseif key == "FGAttempt" then
                if ArurHubData.lastGameTotal ~= nil and val > ArurHubData.lastGameTotal then
                    ArurHubData.sessionTotal = ArurHubData.sessionTotal + (val - ArurHubData.lastGameTotal)
                end
                ArurHubData.lastGameTotal = val
                ArurHubData.updateStatsUI()
            end
        end
    end)
end

