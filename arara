function ArurHubData.findTheBall()
    local char = lp.Character
    if not char then return nil end
    local ballInChar = char:FindFirstChild("Basketball") or char:FindFirstChild("Ball")
    if ballInChar then
        for _, obj in ipairs(workspace:GetChildren()) do
            if obj.Name == "Basketball" and obj ~= char then
                local p = obj:FindFirstChildOfClass("BasePart") or (obj:IsA("BasePart") and obj)
                if p and (p.Position - char.HumanoidRootPart.Position).Magnitude < 10 then
                    return obj 
                end
            end
        end
        return ballInChar
    end
    return nil
end

