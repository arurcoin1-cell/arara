local cachedTrajectoryPoints = {}

run_service.RenderStepped:Connect(function()
    local rimPart, dist = getNearestRim()
    local maxDist = ArurHubData.IsLateGame and 80 or 74
    if ArurHubData.NoJumpEnabled and not ArurHubData.AimbotEnabled then
        maxDist = 68
    end
    local inRangeOfHoop = dist <= maxDist

    -- Range Indicator Update
    if ArurHubData.ShowRange and ArurHubData.HasBall() then
        local aimActive = ArurHubData.AimbotEnabled or ArurHubData.NoJumpEnabled
        if ArurHubData.OnlyShowWithAimbot and not aimActive then
            rangeLabel.Visible = false
            highlight.Enabled = false
        else
            if ArurHubData.RangeMode == 'Outline' then
                rangeLabel.Visible = false
                highlight.Enabled = true
                highlight.OutlineColor = inRangeOfHoop and ArurHubData.InRangeColor or ArurHubData.OutRangeColor
                highlight.FillColor = inRangeOfHoop and ArurHubData.InRangeColor or ArurHubData.OutRangeColor
            else
                highlight.Enabled = false
                rangeLabel.Visible = true
                rangeLabel.Text = inRangeOfHoop and 'In Range' or 'Out of Range'
                rangeLabel.TextColor3 = inRangeOfHoop and ArurHubData.InRangeColor or ArurHubData.OutRangeColor
                rangeLabel.AnchorPoint = Vector2.new(0.5, ArurHubData.RangeMode == 'Top' and 0 or 1)
                rangeLabel.Position = UDim2.new(0.5, 0, ArurHubData.RangeMode == 'Top' and 0.1 or 0.9, 0)
            end
        end
    else
        rangeLabel.Visible = false
        highlight.Enabled = false
    end

    -- Trajectory Update
    local head = lp.Character and lp.Character:FindFirstChild("Head")
    local root = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
    local showTraj = ArurHubData.TrajectoryEnabled and ArurHubData.HasBall() and head and rimPart and inRangeOfHoop
    local aimActive = ArurHubData.AimbotEnabled or ArurHubData.NoJumpEnabled
    if showTraj and ArurHubData.OnlyShowTrajWithAimbot and not aimActive then
        showTraj = false
    end

    local finalPoints = nil
    local finalColor = ArurHubData.TrajectoryColor
    local finalTrans = ArurHubData.TrajectoryTransparency
    local finalMode = ArurHubData.TrajectoryMode

    if showTraj then
        local arcBaseValue
        local vOff = Vector3.zero

        if ArurHubData.NoJumpEnabled then
            arcBaseValue = noJumpArc(dist)
            if root then
                local tVel = Vector3.new(root.AssemblyLinearVelocity.X, 0, root.AssemblyLinearVelocity.Z)
                local toRim = (rimPart.Position - root.Position).Unit
                local rVec = Vector3.new(-toRim.Z, 0, toRim.X)
                local fSpeed = tVel:Dot(toRim)
                local sSpeed = tVel:Dot(rVec)

                local fMult
                if ArurHubData.NoJumpMode == "High Arc" then
                    fMult = (fSpeed > 0) and 0.08 or 0.05
                else
                    fMult = (fSpeed > 0) and 0.03 or 0.05
                end
                arcBaseValue = arcBaseValue - (fSpeed * fMult)
                vOff = rVec * (sSpeed * 0.1)
            end
        else
            arcBaseValue = (ArurHubData.AimbotMode == 'Low Arc' and arcLow(dist)) or (ArurHubData.AimbotMode == 'High Arc' and arcHigh(dist)) or arcLow(dist)
            if root then
                local tVel = Vector3.new(root.AssemblyLinearVelocity.X, 0, root.AssemblyLinearVelocity.Z)
                local toRim = (rimPart.Position - root.Position).Unit
                local rVec = Vector3.new(-toRim.Z, 0, toRim.X) 
                local fSpeed = tVel:Dot(toRim)
                local sSpeed = tVel:Dot(rVec)
                if math.abs(fSpeed) > math.abs(sSpeed) then
                    if fSpeed > 0 then vOff = toRim * (-0.2 * fSpeed) else vOff = toRim * (-0.5 * fSpeed) end
                else
                    vOff = rVec * (0.1 * sSpeed)
                end
            end
        end
        
        local waitTime = ArurHubData.NoJumpEnabled and 0 or (ArurHubData.RandomizeWait and (math.random(15, 25) / 100) or ArurHubData.JumpWaitTime)
        local arcBonus = (not ArurHubData.NoJumpEnabled) and (waitTime > 0.25 and 5 or 0) or 0
        local arcV = arcBaseValue + arcBonus
        
        local p = head.Position
        local targetEnd = rimPart.Position
        local control = ((p + targetEnd) / 2) + Vector3.new(0, arcV * 0.95, 0)
        
        table.clear(cachedTrajectoryPoints)
        local maxT = ArurHubData.TrajectoryStopAtHoop and 1 or 1.25 -- Extend if toggle off
        for i = 0, 30 do
            local t = (i / 30) * maxT
            table.insert(cachedTrajectoryPoints, (1-t)^2*p + 2*(1-t)*t*control + t^2*targetEnd)
        end
        finalPoints = cachedTrajectoryPoints
    elseif ArurHubData.TrajectoryEnabled and (tick() - lastShotInfo.time) < ArurHubData.TrajectoryStayDuration then
        finalPoints = lastShotInfo.points
        finalColor = lastShotInfo.color
        finalTrans = lastShotInfo.trans
        finalMode = lastShotInfo.mode
    end

    if finalPoints and #finalPoints > 1 then
        traj_active = true
        local style   = BEAM_STYLES[currentBeamStyle] or BEAM_STYLES["Plain"]
        local isPlain = currentBeamStyle == "Plain"
        local hasParticles = style.particles and #style.particles > 0

        -- Always position dots so particle emitters fire from the right places
        for i, dot in ipairs(dotPool) do
            if finalPoints[i] then dot.Position = finalPoints[i] end
        end

        if finalMode == "Dots" then
            -- Hide all beam layers
            for layer = 1, NUM_BEAM_LAYERS do
                for _, b in ipairs(beamLayers[layer]) do b.Enabled = false end
            end
            -- Show dots
            for i, dot in ipairs(dotPool) do
                if finalPoints[i] then
                    dot.Transparency = finalTrans
                    dot.Color = finalColor
                else
                    dot.Transparency = 1
                end
            end
        else -- Line / Beam mode
            for _, d in ipairs(dotPool) do d.Transparency = 1 end
            -- Render each active beam layer
            for layer = 1, NUM_BEAM_LAYERS do
                local bd = style.beams[layer]
                local pool = beamLayers[layer]
                local apool = attLayers[layer]
                if bd or (isPlain and layer == 1) then
                    for i = 1, #finalPoints - 1 do
                        local b    = pool[i]
                        local atts = apool[i]
                        if b and atts then
                            atts[1].WorldPosition = finalPoints[i]
                            atts[2].WorldPosition = finalPoints[i+1]
                            if isPlain then
                                b.Color = ColorSequence.new(finalColor)
                                b.Transparency = NumberSequence.new(finalTrans)
                                b.Width0 = 0.4; b.Width1 = 0.4
                                b.Texture = ""; b.TextureSpeed = 0
                            end
                            b.Enabled = true
                        end
                    end
                    for i = #finalPoints, #pool do
                        if pool[i] then pool[i].Enabled = false end
                    end
                else
                    for _, b in ipairs(pool) do b.Enabled = false end
                end
            end
        end

        -- Enable particles along arc (per dot position)
        for i, dotPE in ipairs(dotParticleSets) do
            for p = 1, NUM_PARTICLE_TYPES do
                local pe = dotPE[p]
                local pd = hasParticles and style.particles[p]
                if pd and finalPoints[i] then
                    pe.Rate    = pd.rate
                    pe.Enabled = true
                else
                    pe.Rate    = 0
                    pe.Enabled = false
                end
            end
        end
    else
        if traj_active then
