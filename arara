-- Apply a beam style preset to all pools
function ArurHubData.applyBeamStyle(name)
    currentBeamStyle = name
    local style = BEAM_STYLES[name] or BEAM_STYLES["Plain"]
    for layer = 1, NUM_BEAM_LAYERS do
        local bd = style.beams[layer]
        for _, b in ipairs(beamLayers[layer]) do
            if bd then
                b.Texture        = bd.tex
                b.TextureSpeed   = bd.speed
                b.TextureLength  = bd.len
                b.TextureMode    = bd.mode
                b.Width0         = bd.w0
                b.Width1         = bd.w1
                b.FaceCamera     = bd.cam
                b.LightEmission  = bd.emit
                b.LightInfluence = bd.inf
                b.Color          = ColorSequence.new(bd.col)
                b.Transparency   = NumberSequence.new(bd.trans)
            else
                b.Enabled = false
            end
        end
    end
    for _, dotPE in ipairs(dotParticleSets) do
        for p = 1, NUM_PARTICLE_TYPES do
            local pe = dotPE[p]
            local pd = style.particles[p]
            if pd then
                pe.Texture        = pd.tex
                pe.LightEmission  = pd.emit
                pe.LightInfluence = pd.inf
                pe.RotSpeed       = pd.rotspd
                pe.Rotation       = pd.rot
                pe.SpreadAngle    = pd.spread
                pe.Speed          = pd.spd
                pe.Lifetime       = pd.life
                pe.Size           = pd.size
                pe.Transparency   = pd.trans
                pe.Color          = ColorSequence.new(pd.col)
            end
            pe.Rate    = 0
            pe.Enabled = false
        end
    end
end
