function ArurHubData.watchCurrentGame()
    local char = lp.Character
    local bball = char and char:FindFirstChild("Basketball")
    
    if not bball then
        blockedRim = nil
        ArurHubData.MilleniumRoster = {}
        return
    end

    local gameFolder = bball:FindFirstChild("[GAME]")
    local curGame = gameFolder and gameFolder:FindFirstChild("CurrentGame")
    local courtModel = curGame and curGame.Value

    if courtModel and typeof(courtModel) == "Instance" and courtModel:IsA("Model") then
        local courtPlayers = courtModel:FindFirstChild("_CourtPlayers")
        if courtPlayers then
            local myTeamPrefix = nil
            -- Detect my team assignment (Home/Away 1-5 as requested)
            for i = 1, 5 do
                local h = courtPlayers:FindFirstChild("Home"..i)
                if h and h.Value == lp then myTeamPrefix = "Home"; break end
                local a = courtPlayers:FindFirstChild("Away"..i)
                if a and a.Value == lp then myTeamPrefix = "Away"; break end
            end

            if myTeamPrefix then
                -- Cache the blocked rim
                local hoop = courtModel:FindFirstChild(myTeamPrefix.."Hoop")
                if hoop then 
                    blockedRim = hoop:FindFirstChild("hoop") or hoop.PrimaryPart or hoop:FindFirstChildWhichIsA("BasePart", true)
                end
                
                -- Cache all teammates
                local newRoster = {}
                for i = 1, 5 do
                    local slot = courtPlayers:FindFirstChild(myTeamPrefix..i)
                    if slot and slot.Value and slot.Value ~= lp then
                        newRoster[slot.Value] = true
                    end
                end
                ArurHubData.MilleniumRoster = newRoster
                return
            end
        end
    end

    blockedRim = nil
    ArurHubData.MilleniumRoster = {}
end

