function ArurHubData.SendNotification(message, time, color)
    if ArurHubData.HideNotifications then return end
    if getgenv and getgenv().ArurHub_SuppressNotifs then return end
    time = time or 5
    color = color or Color3.fromRGB(130, 120, 255)

    local CARD_W    = 260
    local CARD_H    = 44
    local STACK_GAP = CARD_H + 8
    local idx       = #notifications + 1
    local startY    = -(60 + (idx - 1) * STACK_GAP)

    -- Root holder (slides in from right)
    local notifHolder = Instance.new('Frame')
    notifHolder.Name          = 'NotifCard'
    notifHolder.Size          = UDim2.fromOffset(CARD_W, CARD_H)
    notifHolder.Position      = UDim2.new(1, 20, 1, startY)
    notifHolder.AnchorPoint   = Vector2.new(0, 1)
    notifHolder.BackgroundTransparency = 1
    notifHolder.Parent        = notificationGui
    notifHolder.ZIndex        = 1400

    -- Dark card background
    local card = Instance.new('Frame', notifHolder)
    card.Size                 = UDim2.fromScale(1, 1)
    card.BackgroundColor3     = Color3.fromRGB(18, 18, 22)
    card.BackgroundTransparency = 0.05
    card.BorderSizePixel      = 0
    card.ClipsDescendants     = true
    card.ZIndex               = 1400
    Instance.new('UICorner', card).CornerRadius = UDim.new(0, 10)

    -- Subtle outer stroke
    local stroke = Instance.new('UIStroke', card)
    stroke.Color       = Color3.fromRGB(60, 60, 70)
    stroke.Thickness   = 1
    stroke.Transparency = 0.5

    -- Colored left accent bar
    local accent = Instance.new('Frame', card)
    accent.Size              = UDim2.new(0, 3, 1, -12)
    accent.Position          = UDim2.new(0, 8, 0, 6)
    accent.AnchorPoint       = Vector2.new(0, 0)
    accent.BackgroundColor3  = color
    accent.BorderSizePixel   = 0
    accent.ZIndex            = 1401
    Instance.new('UICorner', accent).CornerRadius = UDim.new(1, 0)

    -- Message text
    local label = Instance.new('TextLabel', card)
    label.Size                = UDim2.new(1, -28, 1, 0)
    label.Position            = UDim2.new(0, 20, 0, 0)
    label.BackgroundTransparency = 1
    label.TextColor3          = Color3.fromRGB(230, 230, 235)
    label.TextStrokeTransparency = 1
    label.Text                = message
    label.Font                = Enum.Font.GothamMedium
    label.TextSize            = 13
    label.TextXAlignment      = Enum.TextXAlignment.Left
    label.TextYAlignment      = Enum.TextYAlignment.Center
    label.TextTruncate        = Enum.TextTruncate.AtEnd
    label.ZIndex              = 1402

    -- Progress bar (shrinks over `time` seconds)
    local progressBg = Instance.new('Frame', card)
    progressBg.Size              = UDim2.new(1, -30, 0, 2)
    progressBg.Position          = UDim2.new(0, 20, 1, -5)
    progressBg.AnchorPoint       = Vector2.new(0, 1)
    progressBg.BackgroundColor3  = Color3.fromRGB(40, 40, 50)
    progressBg.BorderSizePixel   = 0
    progressBg.ZIndex            = 1403
    Instance.new('UICorner', progressBg).CornerRadius = UDim.new(1, 0)

    local progressBar = Instance.new('Frame', progressBg)
    progressBar.Size             = UDim2.fromScale(1, 1)
    progressBar.BackgroundColor3 = color
    progressBar.BorderSizePixel  = 0
    progressBar.ZIndex           = 1404
    Instance.new('UICorner', progressBar).CornerRadius = UDim.new(0, 2)

    -- Slide in
    local slideIn = tween_service:Create(notifHolder,
        TweenInfo.new(0.3, Enum.EasingStyle.Quint, Enum.EasingDirection.Out),
        {Position = UDim2.new(1, -(CARD_W + 12), 1, startY)}
    )
    slideIn:Play()

    -- Shrink progress bar
    tween_service:Create(progressBar,
        TweenInfo.new(time, Enum.EasingStyle.Linear),
        {Size = UDim2.fromScale(0, 1)}
    ):Play()

    table.insert(notifications, notifHolder)

    local function removeNotification()
        local tweenOut = tween_service:Create(notifHolder,
            TweenInfo.new(0.25, Enum.EasingStyle.Quint, Enum.EasingDirection.In),
            {Position = UDim2.new(1, 20, 1, notifHolder.Position.Y.Offset)}
        )
        tweenOut:Play()
        tweenOut.Completed:Wait()
        notifHolder:Destroy()

        for i, v in ipairs(notifications) do
            if v == notifHolder then table.remove(notifications, i) break end
        end
        for i, notif in ipairs(notifications) do
            local newY = -(60 + (i - 1) * STACK_GAP)
            tween_service:Create(notif,
                TweenInfo.new(0.2, Enum.EasingStyle.Quint, Enum.EasingDirection.Out),
                {Position = UDim2.new(1, -(CARD_W + 12), 1, newY)}
            ):Play()
        end
    end

    task.delay(time, removeNotification)
end

