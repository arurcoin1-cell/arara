-- [ DESYNC FEATURE (RAKNET) ] --
local isRaknetSupported = (typeof(raknet) == "table" and raknet.add_send_hook ~= nil)

local desync_sec = plr_col2:section({name = "Desync", default = true})

if isRaknetSupported then
    local raknetHookErred = false
    local desyncHookActive = false

    local function myLagHook(packet)
        if raknetHookErred then return end
        local success, err = pcall(function()
            local bytes = packet.AsArray
            if type(bytes) == "table" and bytes[1] == 0x1B and #bytes >= 5 then
                bytes[2] = 255 -- FF
                bytes[3] = 255
                bytes[4] = 255
                bytes[5] = 255
                packet:SetData(bytes)
            end
        end)
        
        if not success then
            raknetHookErred = true
            pcall(function() raknet.remove_send_hook(myLagHook) end)
            task.spawn(function()
                ArurHubData.SendNotification("Desync Hook Failure (Killed): " .. tostring(err), 10, Color3.fromRGB(255, 50, 50))
                ArurHubData.DesyncEnabled = false
                if desync_toggle then desync_toggle:set(false) end
            end)
        end
    end

    local desync_toggle
    local desyncHookActive = false
    local isReverting = false

    desync_toggle = desync_sec:toggle({
        name = "Enable Desync (Ban Risk)",
        flag = "desync_enabled",
        type = "checkbox",
        enabled = false,
        default = false,
        callback = function(v)
            if isReverting then return end
            
            if v then
                if raknetHookErred then
                    isReverting = true
                    desync_toggle:set(false)
                    isReverting = false
                    ArurHubData.SendNotification("Re-execute script to reset failed hook.", 5, Color3.fromRGB(255, 200, 0))
                    return
                end
                
                local success, err = pcall(function()
                    if not desyncHookActive then
                        raknet.add_send_hook(myLagHook)
                        desyncHookActive = true
                    end
                end)
                
                if success then
                    ArurHubData.DesyncEnabled = true
                    ArurHubData.SendNotification("Desync Enabled", 3, Color3.fromRGB(0, 255, 0))
                else
                    ArurHubData.DesyncEnabled = false
                    isReverting = true
                    desync_toggle:set(false)
                    isReverting = false
                    
                    ArurHubData.SendNotification("Raknet Blocked by Executor.", 7, Color3.fromRGB(255, 50, 50))
                end
            else
                ArurHubData.DesyncEnabled = false
                if desyncHookActive then
                    pcall(raknet.remove_send_hook, myLagHook)
                    desyncHookActive = false
                end
                ArurHubData.SendNotification("Desync Disabled", 3, Color3.fromRGB(255, 0, 0))
            end
        end
    })

    desync_toggle:settings({}):keybind({
        name = "Keybind",
        key = Enum.KeyCode.Unknown,
        mode = "Toggle",
        linked_toggle = "desync_enabled"
    })
else
    desync_sec:button({
        name = "Raknet Required (Missing)",
        callback = function()
            ArurHubData.SendNotification("Desync requires Raknet hooks. Your executor is not compatible.", 5, Color3.fromRGB(255, 100, 100))
        end
    })
end

